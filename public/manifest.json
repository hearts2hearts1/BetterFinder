{
    "manifest_version": 3,
    "name": "BetterFinder",
    "version": "1.0.2",
    "permissions": ["storage", "tabs"],
    "action": {},
    "background": {
        "service_worker": "background.js",
        "type": "module" 
    },
    "content_scripts": [
        {
            "matches": ["https://archershub.dlsu.edu.ph/*"],
            "js": ["api.js", "transformer.js", "parser.js"],
            "type": "module"
        }
    ]
}